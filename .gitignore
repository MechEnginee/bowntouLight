# === 저장소 gitignore (React Three Fiber + Vite 프로젝트) ===

# 의존성 / 빌드 산출물
node_modules/
dist/
dist-ssr/
build/
*.tsbuildinfo
*.local
.vite
coverage

# 로그
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 환경 변수
.env
.env.*
!.env.example

# 에디터 / 도구 설정
.vscode/*
!.vscode/extensions.json
.idea/
.claude/

# OS 생성 파일
.DS_Store
Thumbs.db
*.suo
*.sw?

# Word 임시 파일
~$*.docx
